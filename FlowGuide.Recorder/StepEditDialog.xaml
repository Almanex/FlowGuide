<Window x:Class="FlowGuide.Recorder.StepEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Edit Step" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Instruction Text -->
        <TextBlock Grid.Row="0" Text="Instruction Text:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Name="InstructionTextBox" Grid.Row="1" TextWrapping="Wrap" AcceptsReturn="True" Height="80" Margin="0,0,0,10"/>

        <!-- Action Type -->
        <TextBlock Grid.Row="2" Text="Action Type:" FontWeight="Bold" Margin="0,0,0,5"/>
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,0,0,15">
            <RadioButton Name="NormalClickRadio" Content="Normal Click" GroupName="ActionType" Margin="0,0,0,5" Checked="ActionTypeChanged"/>
            <RadioButton Name="SystemActionRadio" Content="System Action" GroupName="ActionType" Checked="ActionTypeChanged"/>
        </StackPanel>

        <!-- System Action Settings (visible only for SystemAction) -->
        <StackPanel Grid.Row="4" Name="SystemActionPanel" Visibility="Collapsed" Margin="0,0,0,15">
            <TextBlock Text="System Action Type:" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox Name="SystemActionTypeCombo" Margin="0,0,0,10">
                <ComboBoxItem Content="OpenStartMenu"/>
                <ComboBoxItem Content="OpenSettings"/>
                <ComboBoxItem Content="OpenCommandPrompt"/>
                <ComboBoxItem Content="OpenFileExplorer"/>
                <ComboBoxItem Content="OpenTaskManager"/>
                <ComboBoxItem Content="OpenRun"/>
                <ComboBoxItem Content="OpenNotifications"/>
                <ComboBoxItem Content="OpenActionCenter"/>
            </ComboBox>

            <TextBlock Text="MS-Settings Command (optional):" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox Name="MsSettingsCommandTextBox" Margin="0,0,0,5"/>
            <TextBlock Text="Example: ms-settings:display" FontSize="10" Foreground="Gray" Margin="0,0,0,10"/>

            <CheckBox Name="ShowAutoExecuteCheckBox" Content="Show 'Auto Execute' button in Player" IsChecked="True"/>
        </StackPanel>

        <!-- Save/Cancel Buttons -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save" Width="80" Margin="0,0,10,0" Click="Save_Click" Background="#FF4CAF50" Foreground="White" FontWeight="Bold"/>
            <Button Content="Cancel" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
