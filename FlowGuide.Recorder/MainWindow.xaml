<Window x:Class="FlowGuide.Recorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FlowGuide.Recorder"
        mc:Ignorable="d"
        Title="FlowGuide Recorder - PoC" Height="600" Width="900"
        Background="#1E1E1E">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" 
                   Text="FlowGuide Recorder" 
                   FontSize="24" 
                   FontWeight="Bold"
                   Foreground="White"
                   Margin="0,0,0,20"/>

        <!-- Настройки записи -->
        <Border Grid.Row="1" 
                Background="#2D2D30" 
                Padding="15" 
                CornerRadius="5"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock Text="Настройки гайда:" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="#4EC9B0"
                           Margin="0,0,0,10"/>
                
                <TextBlock Text="Название:" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="GuideTitleInput" 
                         Text="Новый гайд" 
                         Padding="5"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Автор:" Foreground="White" Margin="0,0,0,5"/>
                <TextBox x:Name="AuthorInput" 
                         Text="User" 
                         Padding="5"/>
            </StackPanel>
        </Border>

        <!-- Статус -->
        <Border Grid.Row="2" 
                Background="#252526" 
                BorderBrush="#3E3E42" 
                BorderThickness="1"
                CornerRadius="5"
                Padding="10"
                Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Статус: " Foreground="#DCDCAA" FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Text="Готов к записи" Foreground="White"/>
                <TextBlock Text=" | Шагов записано: " Foreground="#DCDCAA" FontWeight="Bold" Margin="20,0,0,0"/>
                <TextBlock x:Name="StepsCountText" Text="0" Foreground="White"/>
            </StackPanel>
        </Border>

        <!-- Лог событий (вместо детальной инфо) -->
        <Border Grid.Row="3" 
                Background="#1E1E1E" 
                BorderBrush="#3E3E42" 
                BorderThickness="1"
                CornerRadius="5"
                Padding="10">
            <ScrollViewer x:Name="LogScrollViewer">
                <TextBlock x:Name="LogText" 
                           Foreground="#808080" 
                           FontFamily="Consolas"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="4" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0">
            <Button x:Name="LaunchRecorderBtn" 
                    Content="🚀 Запустить Рекордер" 
                    Click="LaunchRecorderBtn_Click"
                    Background="#0E639C" 
                    Foreground="White"
                    Padding="20,10"
                    FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand"
                    Margin="0,0,10,0">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#0E639C"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1177BB"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            
            <Button x:Name="EditGuideBtn" 
                    Content="✏️ Редактировать Гайд" 
                    Click="EditGuideBtn_Click"
                    Background="#4CAF50" 
                    Foreground="White"
                    Padding="20,10"
                    FontSize="14"
                    FontWeight="Bold"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="#4CAF50"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5DBF60"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
